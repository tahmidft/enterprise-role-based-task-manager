JWT_SECRET=your-secret-key-here
JWT_EXPIRATION=24h

# Postgres connection string (Supabase/Railway/Render)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# API port
PORT=3333

# TypeORM toggles (demo-friendly defaults; disable synchronize in real prod)
DB_SSL=true
DB_SYNCHRONIZE=false
DB_LOGGING=false
