# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=task_manager
DB_SSL=true
DB_SYNCHRONIZE=false
DB_LOGGING=false

# JWT
JWT_SECRET=replace-with-a-strong-secret-32-chars-min
JWT_EXPIRATION=15m
REFRESH_TOKEN_TTL_DAYS=7

# Email (Resend)
RESEND_API_KEY=re_your_api_key
RESEND_FROM=noreply@yourdomain.com

# Server
PORT=3333
CORS_ORIGIN=https://your-dashboard.vercel.app
NODE_ENV=production
