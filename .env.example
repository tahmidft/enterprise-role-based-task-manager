JWT_SECRET=your-secret-key-here
JWT_EXPIRATION=24h

# Postgres connection string (local/dev example)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/task_manager

# API port
PORT=3333

# TypeORM toggles (demo-friendly defaults; disable synchronize in real prod)
DB_SSL=false
DB_SYNCHRONIZE=true
DB_LOGGING=false