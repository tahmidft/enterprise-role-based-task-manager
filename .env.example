JWT_SECRET=your-secret-key-here
JWT_EXPIRATION=15m
REFRESH_TOKEN_TTL_DAYS=7

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=task_manager

# API port
PORT=3333

# TypeORM toggles (use false + migrations in production)
DB_SSL=false
DB_SYNCHRONIZE=false
DB_LOGGING=false

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:4200

# Priority aging (nightly cron)
LOW_TO_MEDIUM_DAYS=5
MEDIUM_TO_HIGH_DAYS=3